# PostgreSQL (paste from Vercel/Neon). If using Vercel Neon integration, POSTGRES_PRISMA_URL also works.
DATABASE_URL="postgresql://user:password@host:5432/neondb?sslmode=require"
# POSTGRES_PRISMA_URL=""  # optional — auto-mapped to DATABASE_URL when set by Vercel

# Random secret for admin session JWT (generate with: openssl rand -base64 32)
AUTH_SECRET="change-me-to-a-long-random-string"
